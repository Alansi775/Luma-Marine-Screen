rules_version = '2';

// v1 shape: a single admin account (Firebase Authentication, email/password
// — see the hidden long-press admin flow in the frontend) manages the shared
// video catalog, named playlists, and which playlist is active per device.
// Devices don't have their own credentials yet (see
// backend/schema/firestore-schema.md's "documented, not yet created" section
// for future device registration), so reads are public — acceptable for now
// since this is non-sensitive signage content, not private data. Writes
// require being signed in as the admin, which today means "any authenticated
// user," since only the admin account exists.
//
// Tighten this once real per-device authentication exists: reads should
// become scoped to `isAuthenticatedDevice()` the same way writes are scoped
// to the admin below.
service cloud.firestore {
  match /databases/{database}/documents {
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /playlists/{playlistId} {
      allow read: if true;
      allow write: if isAdmin();

      match /entries/{entryId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /devices/{deviceId} {
      allow read: if true;
      allow write: if isAdmin();

      // Not implemented yet — see backend/schema/firestore-schema.md.
      match /health/{logId} {
        allow read, write: if false;
      }

      match /commands/{commandId} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null;
    }
  }
}
