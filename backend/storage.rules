rules_version = '2';

// Same reasoning as firestore.rules: public read (no device auth exists
// yet, and this is non-sensitive signage content), admin-only write.
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Written only by the processUploadedVideo Cloud Function via the
    // Admin SDK, which bypasses these rules entirely — `allow write: if
    // false` here is just making that explicit, not actually gating it.
    match /thumbnails/{thumbnailId} {
      allow read: if true;
      allow write: if false;
    }

    // Device-safe transcoded copy, generated only when an original in
    // videos/ exceeds the signage hardware's decode envelope. The
    // original is never modified or deleted — this is purely additive,
    // so full-quality source is always preserved even if the video the
    // device actually plays is a resized copy.
    match /videos_playback/{videoId} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
