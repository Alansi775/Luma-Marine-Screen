rules_version = '2';

// Same reasoning as firestore.rules: public read (no device auth exists
// yet, and this is non-sensitive signage content), admin-only write.
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Written only by the generateVideoThumbnail Cloud Function via the
    // Admin SDK, which bypasses these rules entirely — `allow write: if
    // false` here is just making that explicit, not actually gating it.
    match /thumbnails/{thumbnailId} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
