rules_version = '2';

// Same reasoning as firestore.rules: public read (no device auth exists
// yet, and this is non-sensitive signage content), admin-only write.
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
